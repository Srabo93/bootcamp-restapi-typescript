{
  "title": "OTel HTTP — Bootcamp API",
  "uid": "otel-http",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "query": "label_values(http_server_request_duration_ms_count, http_route)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_ms_count{http_route=~\"$route\"}[$__rate_interval])) by (http_route)",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(http_server_request_duration_ms_bucket{http_route=~\"$route\"}[$__rate_interval])) by (le, http_route))",
          "legendFormat": "p50 {{http_route}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_ms_bucket{http_route=~\"$route\"}[$__rate_interval])) by (le, http_route))",
          "legendFormat": "p95 {{http_route}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_ms_bucket{http_route=~\"$route\"}[$__rate_interval])) by (le, http_route))",
          "legendFormat": "p99 {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_ms_count{http_status_code_class!~\"2..\",http_route=~\"$route\"}[$__rate_interval])) by (http_route) / sum(rate(http_server_request_duration_ms_count{http_route=~\"$route\"}[$__rate_interval])) by (http_route) * 100",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "showPoints": "never" },
          "min": 0
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "http_server_active_requests{http_route=~\"$route\"}",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never" }
        }
      }
    }
  ]
}
