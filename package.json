{
  "name": "docker_node_mongo_starter",
  "version": "1.0.0",
  "description": "docker starter with node js and mongodb services",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "format": "prettier --write {**/,}*.js",
    "lint": "prettier --check {**/,}*.js",
    "seed:db": "tsx seeder -i",
    "delete:db": "tsx seeder -d",
    "container": "docker compose up -d",
    "dev": "tsx watch ./server.ts"
  },
  "author": "Armin Srabovic",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.18.2",
    "bottleneck": "^2.19.5",
    "cookie-parser": "^1.4.4",
    "cors": "^2.8.4",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.9.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-geocoder": "^4.2.0",
    "nodemailer": "^6.9.1",
    "pino": "^8.11.0",
    "slugify": "^1.6.5",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/multer": "^1.4.7",
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/morgan": "^1.9.4",
    "@types/node": "^24.0.0",
    "@types/node-geocoder": "^4.2.1",
    "@types/nodemailer": "^6.4.7",
    "prettier": "^2.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.0.3"
  }
}
